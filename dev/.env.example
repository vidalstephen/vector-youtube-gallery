# Vector YouTube Gallery — Local Dev Environment
# Copy to dev/.env and edit. NEVER commit dev/.env.

# --- Database (matches docker-compose.yml) ---
DB_NAME=wordpress
DB_USER=wordpress
DB_PASSWORD=changeme_db_user_password
DB_ROOT_PASSWORD=changeme_root_password

# --- Host ports ---
WP_PORT=8000
ADMINER_PORT=8080

# --- WordPress (used by wp-cli core install) ---
WP_TITLE=VYG Dev
WP_ADMIN_USER=admin
WP_ADMIN_PASSWORD=changeme_wp_admin_password
WP_ADMIN_EMAIL=dev@example.org

# --- VYG Mock API mode (Phase 1+) ---
# When 1, the plugin uses MockApiClient (fixtures from tests/fixtures/) instead of real YouTube.
# When 0, you'd need a real GOOGLE_API_KEY (we won't do this in dev).
VYG_USE_MOCK=1