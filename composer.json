{
    "name": "vectoryt/vector-youtube-gallery",
    "description": "Local-indexed YouTube gallery system for WordPress.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpstan/phpstan": "^1.11",
        "wp-phpunit/wp-phpunit": "^6.5",
        "brain/monkey": "^2.6",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "VectorYT\\Gallery\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VectorYT\\Gallery\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=unit",
        "test:integration": "phpunit --testsuite=integration",
        "phpcs": "phpcs --standard=WordPress src/",
        "phpstan": "phpstan analyse src/",
        "lint": "composer run phpcs && composer run phpstan"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}